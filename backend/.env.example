# FinRelief AI Backend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.

# Database
DATABASE_URL=sqlite:///./finrelief.db

# Authentication — generate your own key: openssl rand -hex 32
SECRET_KEY=your_jwt_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Gemini AI — obtain from https://aistudio.google.com/app/apikey
# Leave blank to use rule-based fallback engine instead of AI.
GEMINI_API_KEY=your_gemini_api_key_here

# App
DEBUG=True
ENVIRONMENT=development
