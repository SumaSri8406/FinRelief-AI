# FinRelief AI Backend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to version control.

# Database Configuration (Defaults to SQLite for local development)
DATABASE_URL=sqlite:///./finrelief.db

# JWT Authentication (Generate a secure key using: openssl rand -hex 32)
SECRET_KEY=your_jwt_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Google Gemini AI Key (Obtain from https://aistudio.google.com/app/apikey)
# If left blank, the platform automatically switches to its rule-based fallback engine.
GEMINI_API_KEY=

# Production/Development Settings
DEBUG=False
ENVIRONMENT=production
